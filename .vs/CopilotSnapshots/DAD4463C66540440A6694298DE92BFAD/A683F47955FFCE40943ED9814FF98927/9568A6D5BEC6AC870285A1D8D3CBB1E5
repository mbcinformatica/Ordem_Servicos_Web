@{
    var mensagem = TempData["Mensagem"]?.ToString();
    var tipo = TempData["MensagemTipo"]?.ToString()?.ToLower();
    var titulo = tipo switch { "erro" => "Erro", "aviso" => "Aviso", "informacao" => "Informação", _ => "Sucesso" };
    var icone = tipo switch { "erro" => "fa-times-circle", "aviso" => "fa-exclamation-circle", "informacao" => "fa-info-circle", _ => "fa-check-circle" };
    var classeMensagem = tipo switch { "erro" => "mensagem-erro-modal", "aviso" => "mensagem-aviso-modal", "informacao" => "mensagem-info-modal", _ => "mensagem-sucesso-modal" };
}

@if (!string.IsNullOrEmpty(mensagem))
{
    <div class="modal fade" id="mensagemModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content-tempdata text-center @classeMensagem">

                <!-- Cabeçalho com ícone + título -->
                <div class="modal-header d-flex justify-content-center align-items-center fw-bold fs-5">
                    <i class="fa @icone me-2"></i>
                    <span>@titulo</span>
                </div>

                <!-- Corpo com mensagem + botão -->
                <div class="modal-body text-center fw-bold fs-5">
                    <span>@mensagem</span>
                    <div class="mt-4">
                        <button type="button" class="btn-ok" data-bs-dismiss="modal">OK</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            var modalElement = document.getElementById("mensagemModal");
            if (modalElement) {
                var modal = new bootstrap.Modal(modalElement);
                modal.show();

                // aplica fade-out ao clicar em OK
                const btnOk = modalElement.querySelector(".btn-ok");
                if (btnOk) {
                    btnOk.addEventListener("click", function () {
                        const content = modalElement.querySelector(".modal-content");
                        content.classList.add("fade-out");
                        setTimeout(() => modal.hide(), 800);
                    });
                }
            }
        });
    </script>
}
