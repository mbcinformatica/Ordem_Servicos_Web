@model Ordem_Servicos_Web.Models.PermissaoViewModel

<h2 class="text-center">@ViewData["Title"]</h2>

<partial name="_MensagemToast" />

<form asp-action="Create" method="post">
    <div class="form-group">
        <label>Usuário</label>
        <select asp-for="Permissao.IDUsuario" class="form-control"
                asp-items="@(new SelectList(Model.Usuarios, "IDUsuario", "NomeUsuario"))"></select>
    </div>

    <div class="form-group">
        <label>Menu</label>
        <select asp-for="Permissao.IDMenu" class="form-control"
                asp-items="@(new SelectList(Model.Menus, "IDMenu", "Descricao"))"></select>
    </div>

    <div class="form-group">
        <label>Itens do Menu</label>
        <select asp-for="Permissao.IDItensMenu" class="form-control"
                asp-items="@(new SelectList(Model.ItensMenus, "IDItensMenu", "Descricao"))"></select>
    </div>

    <div class="form-check">
        <input asp-for="Permissao.Executar" class="form-check-input" type="checkbox" />
        <label class="form-check-label">Pode Executar</label>
    </div>
    <div class="form-check">
        <input asp-for="Permissao.Criar" class="form-check-input" type="checkbox" />
        <label class="form-check-label">Pode Criar</label>
    </div>
    <div class="form-check">
        <input asp-for="Permissao.Alterar" class="form-check-input" type="checkbox" />
        <label class="form-check-label">Pode Alterar</label>
    </div>
    <div class="form-check">
        <input asp-for="Permissao.Excluir" class="form-check-input" type="checkbox" />
        <label class="form-check-label">Pode Excluir</label>
    </div>

    <button type="submit" class="btn btn-primary">Salvar</button>
    <a asp-action="Index" class="btn btn-danger">Cancelar</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            bloquearMenu();
        });
    </script>
}
