@model IEnumerable<Ordem_Servicos_Web.Models.Cliente>

@{
    ViewData["Title"] = "Gerenciamento de Clientes";
    int page = ViewBag.Page ?? 1;
    int totalPaginas = ViewBag.TotalPaginas ?? 1;
    int totalRegistros = ViewBag.TotalRegistros ?? 0;
    string search = ViewBag.Search ?? "";
}

<h2 class="text-center">@ViewData["Title"]</h2>

<div class="table-responsive">
    <table class="table-os table-os-striped table-os-bordered table-os-condensed w-100 mb-0">        
        <thead class="table-dark">
            <tr>
                <th style="width:150px;">Ações</th>
                <th class="sortable">ID</th>
                <th>TIPO/PESSOA</th>
                <th class="sortable">CPF/CNPJ</th>
                <th class="sortable">NOME/RAZÃO SOCIAL</th>
                <th>ENDEREÇO</th>
                <th>NÚMERO</th>
                <th>BAIRRO</th>
                <th>MUNICÍPIO</th>
                <th>UF</th>
                <th>CEP</th>
                <th>CONTATO</th>
                <th>CELULAR</th>
                <th>FIXO</th>
                <th>E-MAIL</th>
                <th>DATA CADASTRO</th>
            </tr>
        </thead>

        <tbody id="clientesTable">
            @foreach (var cliente in Model)
            {
                <tr>
                    <td>
                        <a asp-action="Alterar" asp-route-id="@cliente.IdCliente" class="btn btn-alterar btn-sm">
                            <i class="fa fa-edit"></i> Alterar
                        </a>
                        <a asp-action="Excluir" asp-route-id="@cliente.IdCliente" class="btn btn-excluir btn-sm">
                            <i class="fa fa-trash"></i> Excluir
                        </a>
                    </td>
                    <td class="text-end">@cliente.IdCliente</td>
                    <td class="text-center">@cliente.TipoPessoa</td>
                    <td class="text-end">@cliente.CpfCnpjFormatado</td>
                    <td>@cliente.NomeRazaoSocial</td>
                    <td>@cliente.Endereco</td>
                    <td class="text-end">@cliente.Numero</td>
                    <td class="text-end">@cliente.Bairro</td>
                    <td>@cliente.Municipio</td>
                    <td class="text-center">@cliente.Uf</td>
                    <td class="text-center">@cliente.CepFormatado</td>
                    <td>@cliente.Contato</td>
                    <td class="text-center">@cliente.Fone1Formatado</td>
                    <td class="text-center">@cliente.Fone2Formatado</td>
                    <td>@cliente.EmailFormatado</td>
                    <td class="text-end">@cliente.DataCadastro.ToShortDateString()</td>
                </tr>
            }
        </tbody>
    </table>
</div>

<input type="text" id="searchBox" value="@search"
       class="input-pesquisa"
       placeholder="Pesquisar Cliente por Nome..." style="max-width:1000px;" />

<!-- Rodapé -->
<div class="d-flex justify-content-between align-items-center mt-2 flex-wrap">
    <div class="d-flex align-items-center flex-wrap">
        <a class="btn btn-navegacao btn-bg me-2 @(page == 1 ? "disabled" : "")"
           asp-action="Index" asp-route-page="@(page - 1)" asp-route-search="@search">
            <i class="fa fa-arrow-left"></i> Anterior
        </a>

        <span class="fw-bold text-black me-2">Página: @(page) - @totalPaginas</span>

        <a class="btn btn-navegacao btn-bg me-3 @(page == totalPaginas ? "disabled" : "")"
           asp-action="Index" asp-route-page="@(page + 1)" asp-route-search="@search">
            Próximo <i class="fa fa-arrow-right"></i>
        </a>

        <span id="totalRegistros" class="fw-bold text-black me-2">Total de Registros: @totalRegistros</span>
    </div>

    <div class="d-flex gap-2">
        <a asp-action="Create" class="btn btn-novo btn-bg">
            <i class="fa fa-plus"></i> Novo Cliente
        </a>
        <a asp-controller="Home" asp-action="Index" class="btn btn-voltar btn-bg" onclick="liberarMenu()">
            <i class="fa fa-home"></i> Voltar
        </a>
    </div>
</div>

@section Scripts {
    <script>

        let sortDirection = {};
        let currentSortedCol = null;

        document.addEventListener("DOMContentLoaded", function () {
            bloquearMenu();

            if (typeof aplicarFormatacaoTabela === "function") {
                aplicarFormatacaoTabela();
            }
            // Adiciona evento de clique nos cabeçalhos com classe "sortable"
            document.querySelectorAll("th.sortable").forEach((th, index) => {
                th.style.cursor = "pointer";
                th.addEventListener("click", function () {
                    sortTable(index);
                });
            });
        });

        // Busca dinâmica
        document.getElementById("searchBox").addEventListener("keyup", function () {
            var searchValue = this.value.trim();

            if (searchValue.length > 0) {
                fetch('@Url.Action("Search", "Clientes")?search=' + encodeURIComponent(searchValue))
                    .then(response => response.text())
                    .then(html => {
                        document.getElementById("clientesTable").innerHTML = html;

                        var total = document.querySelectorAll("#clientesTable tr").length;
                        document.getElementById("totalRegistros").innerText = "Total de Registros: " + total;

                        // Reaplica formatação nos novos registros (só se presente)
                        if (typeof aplicarFormatacaoTabela === "function") {
                            aplicarFormatacaoTabela();
                        }
                    });
            } 
            else {
                window.location.href = '@Url.Action("Index", "Clientes", new { page = 1 })';
            }
        });

        // Aplica formatação na tabela
        function aplicarFormatacaoTabela() {
            document.querySelectorAll("#clientesTable tr").forEach(tr => {
                let tipoPessoa = tr.children[2]?.innerText;
                let cpfCnpj = tr.children[3];
                let fone1 = tr.children[12];
                let fone2 = tr.children[13];
                let cep = tr.children[10];
                let email = tr.children[14];

                if (cpfCnpj) cpfCnpj.innerText = formatCpfCnpj(cpfCnpj.innerText, tipoPessoa);
                if (fone1) fone1.innerText = formatTelefone(fone1.innerText);
                if (fone2) fone2.innerText = formatTelefone(fone2.innerText);
                if (cep) cep.innerText = formatCep(cep.innerText);
                if (email) email.innerText = converteParaMinusculo(email.innerText);
            });
        }

        function sortTable(colIndex, th) {
            const table = document.querySelector("table");
            const tbody = table.querySelector("tbody");
            const rows = Array.from(tbody.querySelectorAll("tr"));

            sortDirection[colIndex] = !sortDirection[colIndex];

            rows.sort((a, b) => {
                let aCell = a.children[colIndex];
                let bCell = b.children[colIndex];

                if (!aCell || !bCell) return 0; // evita erro

                let aText = aCell.innerText.trim();
                let bText = bCell.innerText.trim();

                // Se for coluna ID, trata como número
                if (colIndex === 1) {
                    let aVal = parseInt(aText, 10);
                    let bVal = parseInt(bText, 10);
                    return sortDirection[colIndex] ? aVal - bVal : bVal - aVal;
                }

                // Caso contrário, ordena como texto
                if (aText < bText) return sortDirection[colIndex] ? -1 : 1;
                if (aText > bText) return sortDirection[colIndex] ? 1 : -1;
                return 0;
            });

            rows.forEach(row => tbody.appendChild(row));

            // Remove ícones e destaque anteriores
            document.querySelectorAll("th.sortable").forEach(header => {
                header.innerText = header.innerText.replace(/[\u2191\u2193]/g, "").trim();
                header.classList.remove("active");
            });

            // Adiciona ícone e destaque na coluna atual
            th.innerText = th.innerText + (sortDirection[colIndex] ? " ↑" : " ↓");
            th.classList.add("active");
        }

    </script>
}