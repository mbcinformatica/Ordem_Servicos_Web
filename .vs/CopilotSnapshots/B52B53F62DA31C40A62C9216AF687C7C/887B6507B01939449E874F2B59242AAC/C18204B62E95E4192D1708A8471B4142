@model Ordem_Servicos_Web.Models.Cliente

@{
    ViewData["Title"] = "Alterar Cliente";
}

<h2 class="text-center">@ViewData["Title"]</h2>

<partial name="_MensagemToast" />

<form asp-action="Alterar" method="post" id="formCliente">
    <input type="hidden" asp-for="IdCliente" />
    <!-- Tipo de Pessoa e CPF/CNPJ -->
    <div class="row mb-2 g-4">
        <div class="col-auto">
            <label asp-for="TipoPessoa" class="label-destaque">Tipo de Pessoa</label>
            <input asp-for="TipoPessoa" class="form-control" id="TipoPessoa" readonly style="width:120px;" />
        </div>
        <div class="col-auto">
            <label class="label-destaque">CPF/CNPJ</label>
            <input class="form-control" value="@Model.CpfCnpjFormatado" readonly style="width:170px;" />
            <input type="hidden" asp-for="CpfCnpj" />
        </div>
        <div class="col-auto">
            <label asp-for="NomeRazaoSocial" class="label-destaque">Nome/Razão Social</label>
            <input asp-for="NomeRazaoSocial" class="form-control text-uppercase" required maxlength="150" style="width:615px;" />
            <span asp-validation-for="NomeRazaoSocial" class="text-danger"></span>

        </div>
        <div class="col-auto">
            <label asp-for="Cep" class="label-destaque">CEP</label>
            <input asp-for="Cep" type="text" inputmode="numeric" class="form-control" style="width:120px;" />
            <span asp-validation-for="Cep" class="text-danger"></span>
        </div>
    </div>

    <!-- Endereço, Número, Bairro -->
    <div class="row mb-2 g-4">
        <div class="col-auto">
            <label asp-for="Endereco" class="label-destaque">Endereço</label>
            <input asp-for="Endereco" class="form-control text-uppercase" maxlength="100" style="width:515px;" />
        </div>
        <div class="col-auto">
            <label asp-for="Numero" class="label-destaque">Número</label>
            <input asp-for="Numero" id="Numero" type="text" class="form-control text-uppercase" maxlength="10" style="width:100px;" />
        </div>
        <div class="col-auto">
            <label asp-for="Bairro" class="label-destaque">Bairro</label>
            <input asp-for="Bairro" class="form-control text-uppercase" maxlength="50" style="width:435px;" />
        </div>
    </div>

    <!-- Município, UF, CEP -->
    <div class="row mb-2 g-4">
        <div class="col-auto">
            <label asp-for="Municipio" class="label-destaque">Município</label>
            <input asp-for="Municipio" class="form-control text-uppercase" maxlength="100" style="width:450px;" />
        </div>
        <div class="col-auto">
            <label asp-for="Uf" class="label-destaque">UF</label>
            <estado-select asp-for="Uf"></estado-select>
            <span asp-validation-for="Uf" class="text-danger"></span>
        </div>
        <div class="col-auto">
            <label asp-for="Contato" class="label-destaque">Contato</label>
            <input asp-for="Contato" class="form-control text-uppercase" maxlength="50" style="width:400px;" />
        </div>
    </div>

    <!-- Contato, Fones, Email -->
    <div class="row mb-2 g-4">
        <div class="col-auto">
            <label asp-for="Fone1" class="label-destaque">Telefone 1</label>
            <input asp-for="Fone1" type="text" inputmode="numeric" class="form-control" style="width:160px;" />
        </div>
        <div class="col-auto">
            <label asp-for="Fone2" class="label-destaque">Telefone 2</label>
            <input asp-for="Fone2" type="text" inputmode="numeric" class="form-control" style="width:160px;" />
        </div>
        <div class="col-auto">
            <label asp-for="Email" class="label-destaque">Email</label>
            <input asp-for="Email" id="Email" class="form-control text-lowercase" style="width:530px;" />
            <span asp-validation-for="Email" class="text-danger"></span>
        </div>
        <div class="col-auto">
            <label asp-for="DataCadastro" class="label-destaque">Data de Cadastro</label>
            <input asp-for="DataCadastro" type="date" class="form-control" readonly style="width:180px;" />
        </div>
    </div>

    <!-- Botões -->
    <div class="d-flex gap-2 mt-4">
        <button type="submit" id="btnSalvar" class="btn btn-salvar btn-bg">
            <i class="fa fa-save"></i> Salvar Alterações
        </button>
        <a asp-action="Index" class="btn btn-voltar btn-bg">
            <i class="fa fa-arrow-left"></i> Voltar
        </a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            bloquearMenu();
            const nomeRazao = document.getElementById("NomeRazaoSocial");
            const campos = document.querySelectorAll("input, select, textarea");
            const tipoPessoa = document.getElementById("TipoPessoa")?.value;
            const cpfCnpj = document.getElementById("CpfCnpj");
            const fone1 = document.getElementById("Fone1");
            const fone2 = document.getElementById("Fone2");
            const cep = document.getElementById("Cep");
            const email = document.getElementById("Email");
            const btnSalvar = document.getElementById("btnSalvar");
            const form = document.getElementById("formCliente");

            if (nomeRazao) nomeRazao.focus();

            // Enter vai para o próximo campo
            campos.forEach(function (el, index) {
                el.addEventListener("keydown", function (e) {
                    if (e.key === "Enter") {
                        e.preventDefault();
                        const next = campos[index + 1];
                        if (next) {
                            next.focus();
                            next.select();
                        }
                    }
                });
            });

            // Campos de texto que devem ficar em maiúsculo
            document.querySelectorAll("#NomeRazaoSocial, #Endereco, #Numero, #Bairro, #Municipio, #Contato, #Uf")
                .forEach(input => input.addEventListener("blur", () => {
                    input.value = input.value.toUpperCase().trim();
                }));

            // Antes de enviar → remove formatação e garante imagem atual
            if (form) {
                form.addEventListener("submit", function () {
                    if (cep) cep.value = SemFormatacao(cep.value);
                    if (fone1) fone1.value = SemFormatacao(fone1.value);
                    if (fone2) fone2.value = SemFormatacao(fone2.value);
                    if (email) email.value = converteParaMinusculo(email.value);
                    if (cpfCnpj) cpfCnpj.value = SemFormatacao(cpfCnpj.value);
                });
            }

            [cpfCnpj, cep, fone1, fone2].forEach(campo => {
                if (campo) {
                    campo.addEventListener("input", () => apenasNumeros(campo));
                }
            });

            // CEP
            if (cep) {
                cep.addEventListener("blur", () => {
                    cep.value = formatCep(cep.value);
                    if (!validarCep(cep)) {
                        cep.focus();
                    } else {
                        buscarCEP("Cep", "Endereco", "Bairro", "Municipio", "Uf");
                    }
                });
            }

            if (fone1) fone1.addEventListener("blur", () => {
                fone1.value = formatTelefone(fone1.value);
                if (!validarTelefone(fone1)) fone1.focus();
            });

            if (fone2) fone2.addEventListener("blur", () => {
                fone2.value = formatTelefone(fone2.value);
                if (!validarTelefone(fone2)) fone2.focus();
            });

            // Email
            if (email && btnSalvar) {
                email.addEventListener("blur", function () {
                    email.value = converteParaMinusculo(email.value);
                    if (!validarEmail(email)) {
                        email.focus();
                    } else {
                        btnSalvar.focus();
                    }
                });
               // Ao pressionar Enter dentro do campo
                email.addEventListener("keydown", function (e) {
                    if (e.key === "Enter") {
                        e.preventDefault(); // evita submit automático
                        btnSalvar.focus();
                    }
                });
            }
        });
    </script>
}

