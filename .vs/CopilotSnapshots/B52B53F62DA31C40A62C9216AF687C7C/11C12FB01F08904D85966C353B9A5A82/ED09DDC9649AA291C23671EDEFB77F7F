@model IEnumerable<Ordem_Servicos_Web.Models.Usuario>

@{
    ViewData["Title"] = "Login";
}

<partial name="_MensagemToast" />

<div class="login-page gradient-bg d-flex justify-content-center align-items-center ">
    <div class="card shadow-lg translucent-box card-login">
        <div class="card-body">
            <h2 class="text-center mb-4">@ViewData["Title"]</h2>

            <form asp-action="Login" asp-controller="Account" method="post" id="formLogin" enctype="multipart/form-data">
                <div class="mb-3">
                    <label for="login" class="form-label label-destaque">Login</label>
                    <input type="text" id="login" name="login" class="form-control input-login" required tabindex="1" />
                </div>

                <div class="mb-4">
                    <label for="senha" class="form-label label-destaque">Senha</label>
                    <input type="password" id="senha" name="senha" class="form-control input-login" required tabindex="2" />
                </div>

                <!-- Container da imagem e NomeUsuario -->
                <div id="userImageContainer" class="text-center mb-3" style="display:none;">
                    <img id="userImage" src="" alt="Imagem do usuário" class="img-thumbnail" style="max-width:150px;" />
                    <p id="nomeUsuario" class="fw-bold mt-2"></p>
                </div>

                <div class="d-grid">
                    <button type="submit" id="btnEntrar" class="btn-entrar" tabindex="3">Entrar</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            bloquearMenu();
            const loginInput = document.getElementById("login");
            const senhaInput = document.getElementById("senha");
            const userImageContainer = document.getElementById("userImageContainer");
            const userImage = document.getElementById("userImage");
            const nomeUsuario = document.getElementById("nomeUsuario"); // ✅ agora corresponde ao Model
            const form = document.getElementById("formLogin");
            const campos = Array.from(document.querySelectorAll("input, select, textarea"))
                .filter(el => el.type !== 'hidden' && !el.disabled && (el.offsetParent !== null));
            const btnEntrar = document.getElementById("btnEntrar"); 

            if (loginInput) loginInput.focus();

            // Enter vai para o próximo campo (só chama select() se disponível)
            campos.forEach(function (el, index) {
                el.addEventListener("keydown", function (e) {
                    if (e.key === "Enter") {
                        e.preventDefault();
                        const next = campos[index + 1];
                        if (next) {
                            next.focus();
                            if (typeof next.select === 'function') {
                                next.select();
                            }
                        }
                    }
                });
            });

            if (loginInput) {
                loginInput.addEventListener("blur", function () {
                    const loginValue = loginInput.value.trim();
                    if (loginValue.length > 0) {
                        // ✅ Corrigido: usa loginValue
                        fetch(`/Usuarios/VerificarLogin?login=${encodeURIComponent(loginValue)}`)
                            .then(response => response.json())
                            .then(data => {
                                if (data.existe) {
                                    // Se login existe, busca a imagem
                                    fetch(`/Usuarios/GetUserImage?login=${encodeURIComponent(loginValue)}`)
                                        .then(response => response.json())
                                        .then(data => {
                                            console.log("Resposta:", data); // debug
                                            if (data.exists && data.imagemBase64) {
                                                userImage.src = `data:${data.contentType};base64,${data.imagemBase64}`;
                                                userImageContainer.style.display = "block";
                                                nomeUsuario.textContent = data.nome; // ✅ NomeUsuario
                                                // foca no campo senha depois de carregar imagem
                                                //document.getElementById("senha").focus();
                                            } else {
                                                userImageContainer.style.display = "none";
                                                nomeUsuario.textContent = "";
                                            }
                                        })
                                        .catch(err => {
                                            console.error("Erro no fetch:", err);
                                            userImageContainer.style.display = "none";
                                            nomeUsuario.textContent = "";
                                        });
                                } else {
                                    mostrarToast("Login não Cadastrado.", "erro");
                                    loginInput.focus();
                                }
                            })
                            .catch(() => {
                                mostrarToast("Erro ao verificar login.", "erro");
                                loginInput.focus();

                            });
                    }
                });
            }
            // Focar no Botao Entrar
            if (senhaInput && btnEntrar) {
                // Ao sair do campo
                senhaInput.addEventListener("blur", () => {
                    btnEntrar.focus();
                });

                // Ao pressionar Enter dentro do campo
                senhaInput.addEventListener("keydown", function (e) {
                    if (e.key === "Enter") {
                        e.preventDefault(); // evita submit automático
                        btnEntrar.focus();
                    }
                });
            }
        });
    </script>
}