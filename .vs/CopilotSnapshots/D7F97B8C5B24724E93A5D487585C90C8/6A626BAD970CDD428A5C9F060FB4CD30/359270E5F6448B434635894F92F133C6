// Função genérica para aplicar máscara
function aplicarMascara(valor, mascara) {
    valor = valor.replace(/\D/g, "");
    let resultado = "";
    let pos = 0;

    for (let i = 0; i < mascara.length; i++) {
        if (mascara[i] === "9") {
            if (valor[pos]) {
                resultado += valor[pos];
                pos++;
            } else {
                break;
            }
        } else {
            if (pos > 0) { // só adiciona separadores se já houver dígitos
                resultado += mascara[i];
            }
        }
    }
    return resultado;
}

// Função genérica para aplicar máscara com InputMask (suporta fallback para API Inputmask v5)
function aplicarMascaraCampo(inputCampo, tipo) {

    if (!inputCampo) return;

    function aplicarComJQueryMask(el, args) {
        // Se plugin jQuery Inputmask estiver disponível
        if (window.jQuery && typeof jQuery(el).inputmask === 'function') {
            jQuery(el).inputmask.apply(jQuery(el), args);
            return true;
        }
        return false;
    }

    function aplicarComInputmaskGlobal(el, args) {
        // Fallback para Inputmask v5 (API sem jQuery)
        if (window.Inputmask) {
            const first = args[0];
            try {
                if (typeof first === 'string') {
                    if (first === 'currency') {
                        Inputmask({ alias: 'currency', radixPoint: ',', groupSeparator: '.', digits: 2, autoGroup: true, prefix: 'R$ ', rightAlign: false }).mask(el);
                    } else if (first === 'integer') {
                        Inputmask({ alias: 'integer', groupSeparator: '.', autoGroup: true, rightAlign: false }).mask(el);
                    } else {
                        // máscara simples como "99999-999"
                        Inputmask(first).mask(el);
                    }
                } else if (typeof first === 'object') {
                    Inputmask(first).mask(el);
                }
                return true;
            } catch (e) {
                console.error('Inputmask erro ao aplicar máscara (fallback):', e);
            }
        }
        return false;
    }

    function aplicar(el, args) {
        if (aplicarComJQueryMask(el, args)) return;
        if (aplicarComInputmaskGlobal(el, args)) return;
        // Se nenhum plugin disponível, aplica formatação mínima (não interativa)
        const maskArg = args && args[0];
        if (typeof maskArg === 'string' && /9/.test(maskArg)) {
            // tenta formatar apenas o valor atual
            el.value = aplicarMascara(el.value || '', maskArg);
        }
    }

    switch (tipo.toLowerCase()) {
        case "cpf":
            aplicar(inputCampo, ["999.999.999-99"]);
            break;
        case "cnpj":
            aplicar(inputCampo, ["99.999.999/9999-99"]);
            break;
        case "cep":
            aplicar(inputCampo, ["99999-999"]);
            break;
        case "telefone":
            aplicar(inputCampo, [{ mask: ["(99) 9999-9999", "(99) 99999-9999"], keepStatic: true }]);
            break;
        case "valor":
            aplicar(inputCampo, ["currency", { radixPoint: ",", groupSeparator: ".", digits: 2, autoGroup: true, prefix: "R$ ", rightAlign: false }]);
            break;
        case "quantidade":
            aplicar(inputCampo, ["integer", { groupSeparator: ".", autoGroup: true, rightAlign: false }]);
            break;
    }
}

// Função para aplicar CPF ou CNPJ conforme seleção
function aplicarCpfCnpj(campo, tipoPessoa) {
    if (tipoPessoa === "FÍSICA") {
        aplicarMascaraCampo(campo, "cpf");
    } else {
        aplicarMascaraCampo(campo, "cnpj");
    }
}

// Função para permitir apenas números em um campo de input
function apenasNumeros(input) {
    input.value = input.value.replace(/\D/g, "");
}

// Função para formatar CPF ou CNPJ, adaptando a máscara conforme o tipo de pessoa
function formatCpfCnpj(valor, tipoPessoa) {
    valor = valor.replace(/\D/g, "");
    return tipoPessoa === "JURÍDICA"
        ? aplicarMascara(valor, "99.999.999/9999-99")
        : aplicarMascara(valor, "999.999.999-99");
}

// Função para formatar telefone, adaptando para 8 ou 9 dígitos
function formatTelefone(valor) {
    valor = valor.replace(/\D/g, "");
    return valor.length > 10
        ? aplicarMascara(valor, "(99) 99999-9999")
        : aplicarMascara(valor, "(99) 9999-9999");
}

// Função para formatar CEP
function formatCep(valor) {
    valor = valor.replace(/\D/g, "");
    return aplicarMascara(valor, "99999-999");
}

// Função para formatar valor monetário
function formatValor(valor) {
    if (!valor) return "";
    valor = valor.toString().replace(/\D/g, "");
    let numero = (parseFloat(valor) / 100).toFixed(2);
    return new Intl.NumberFormat("pt-BR", {
        style: "currency",
        currency: "BRL"
    }).format(numero);
}

// Função para formatar quantidade com separador de milhar
function formatQuantidade(valor) {
    if (!valor) return "";
    valor = valor.toString().replace(/\D/g, "");
    return new Intl.NumberFormat("pt-BR").format(valor);
}

// Função para converter texto para minúsculo, removendo espaços extras
function converteParaMinusculo(valor) {
    if (!valor) return "";
    return valor.trim().toLowerCase();
}

// Função para remover formatações, deixando apenas os números (e ponto para valores)
function semFormatacao(valor) {
    if (!valor) return "";
    let limpo = valor.replace(/[()\.\-\/R\$\s]/g, "").trim();
    if (valor.includes(",")) {
        limpo = valor.replace(/[R\$\s]/g, "")
            .replace(/\./g, "")
            .replace(",", ".");
    }
    return limpo;
}

// Função para limpar mensagens de erro associadas a um campo de input
function limparErro(input) {
    let span = input.nextElementSibling;
    if (span && span.classList.contains("text-danger")) {
        span.textContent = "";
    }
}

// Função para mostrar mensagens de toast usando Bootstrap, com tipos de erro, aviso e sucesso
function mostrarToast(texto, tipo) {
    const toastContainer = document.querySelector(".mensagem-container");
    const toastEl = document.getElementById("toastMensagem");
    const toastBody = document.getElementById("toastTexto");

    if (!toastEl || !toastBody || !toastContainer) return;

    toastBody.innerText = texto;
    toastEl.className = "mensagem-custom d-inline-flex align-items-center";

    if (tipo === "erro") {
        toastEl.classList.add("mensagem-erro");
    } else if (tipo === "aviso") {
        toastEl.classList.add("mensagem-aviso");
    } else if (tipo === "sucesso") {
        toastEl.classList.add("mensagem-sucesso");
    }

    toastContainer.style.display = "flex";
    const toast = new bootstrap.Toast(toastEl, { delay: 4000 });
    toast.show();
}