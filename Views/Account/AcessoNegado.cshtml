@{
    ViewData["Title"] = "Acesso Negado";
}

<div class="container mt-5 text-center">
    <div class="card shadow-lg border-danger">
        <div class="card-body">
            <h2 class="text-danger">
                <i class="fa fa-ban me-2"></i> Acesso Negado
            </h2>
            <p class="mt-3">
                Você não tem autorização para acessar esta página ou executar esta ação.
            </p>
            <p class="text-muted">
                Se você acredita que isso é um erro, entre em contato com o administrador do sistema.
            </p>
            <div class="mt-4">
                <a asp-controller="Home" asp-action="Index" class="btn btn-primary">
                    <i class="fa fa-home me-2"></i> Voltar ao Início
                </a>
                <a asp-controller="Account" asp-action="Logout" class="btn btn-outline-danger ms-2">
                    <i class="fa fa-sign-out-alt me-2"></i> Logout
                </a>
            </div>
        </div>
    </div>
</div>
