<!-- Toast container centralizado no topo -->
<div class="mensagem-container position-fixed top-0 start-50 translate-middle-x p-3">
    <div id="toastMensagem"
         class="toast mensagem-custom align-items-center border-0"
         role="alert" aria-live="assertive" aria-atomic="true">
        <div class="d-flex">
            <!-- Ícone -->
            <span id="toastIcon" 
                  class="me-4 fs-4" m-auto></span>


            <!-- Texto -->
            <div id="toastTexto" 
                class="toast-body"></div>

            <!-- Botão fechar -->
            <button type="button" 
                class="btn-close fs-4 me-2 m-auto"
                data-bs-dismiss="toast"
                aria-label="Fechar"></button>
        </div>
    </div>
</div>