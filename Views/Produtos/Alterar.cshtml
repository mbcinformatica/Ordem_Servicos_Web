@model Ordem_Servicos_Web.ViewModels.ProdutoViewModel

@{
    ViewData["Title"] = "Alterar Produto";
}

<h2 class="text-center">@ViewData["Title"]</h2>

<partial name="_MensagemToast" />


<form asp-action="Alterar" method="post" id="formProduto" enctype="multipart/form-data">
    <input type="hidden" asp-for="IdProduto" />
    <input type="hidden" asp-for="Descricao" />

    <!-- Linha 1 -->
    <div class="row mb-2 g-4">
        <div class="col-auto">
            <label asp-for="IdProdutoInterno" class="label-destaque">Código Interno</label>
            <input asp-for="IdProdutoInterno" id="IdProdutoInterno" class="form-control maiusculo" style="width:260px;" />
            <input type="hidden" asp-for="IdProdutoInterno" />

        </div>
        <div class="col-auto">
            <label asp-for="IdProdutoFabricante" class="label-destaque">Código Fabricante</label>
            <input asp-for="IdProdutoFabricante" id="IdProdutoFabricante" class="form-control maiusculo" style="width:260px;" />
            <input type="hidden" asp-for="IdProdutoFabricante" />
        </div>
        <div class="col-auto">
            <label class="label-destaque">Nome do Fornecedor</label>
            <input type="text" class="form-control" value="@Model.NomeFornecedor" readonly style="width:525px;" />
            <input type="hidden" asp-for="IdFornecedor" />
        </div>
    </div>

    <!-- Linha 2 -->
    <div class="row mb-2 g-4">
        <div class="col-auto">
            <label class="label-destaque">Descrição da Marca</label>
            <input type="text" class="form-control" value="@Model.NomeMarca" readonly style="width:300px;" />
            <input type="hidden" asp-for="IdMarca" />
        </div>
        <div class="col-auto">
            <label class="label-destaque">Descrição do Modelo</label>
            <input type="text" class="form-control" value="@Model.NomeModelo" readonly style="width:400px;" />
            <input type="hidden" asp-for="IdModelo" />
        </div>
        <div class="col-auto">
            <label class="label-destaque">Descrição da Unidade</label>
            <input type="text" class="form-control" value="@Model.NomeUnidade" readonly style="width:350px;" />
            <input type="hidden" asp-for="IdUnidade" />
        </div>
    </div>

    <!-- Linha 3 -->
    <div class="row mb-2 g-4">
        <div class="col-auto">
            <label asp-for="PrecoCompra" class="label-destaque">Preço Compra</label>
            <input asp-for="PrecoCompra" id="PrecoCompra" type="text" inputmode="numeric" class="form-control text-end" style="width:257px;" autofocus/>
        </div>
        <div class="col-auto">
            <label asp-for="PrecoVenda" class="label-destaque">Preço Venda</label>
            <input asp-for="PrecoVenda" id="PrecoVenda" type="text" inputmode="numeric" class="form-control text-end" style="width:257px;" />
        </div>
        <div class="col-auto">
            <label asp-for="EstoqueAtual" class="label-destaque">Estoque Atual</label>
            <input asp-for="EstoqueAtual" id="EstoqueAtual" type="text" inputmode="numeric" class="form-control text-end" style="width:257px;" />
        </div>
        <div class="col-auto">
            <label asp-for="EstoqueMinimo" class="label-destaque">Estoque Mínimo</label>
            <input asp-for="EstoqueMinimo" id="EstoqueMinimo" type="text" inputmode="numeric" class="form-control text-end" style="width:257px;" />
        </div>
    </div>

    <!-- Linha 4 -->
    <div class="row mb-2 g-4">
         <div class="col-auto">
             <label for="Imagem" class="label-destaque">Imagem do Produto</label>
             <input type="file" id="Imagem" name="Imagem" class="form-control" accept="image/*" />
         </div>
    </div>

    <div class="row mb-2 g-4">
        <div class="col-auto">
            @if (Model.Imagem != null)
            {
                <input type="hidden" name="ImagemBase64" value="@Convert.ToBase64String(Model.Imagem)" />
                <img src="data:image/png;base64,@Convert.ToBase64String(Model.Imagem)"
                     alt="Foto atual" style="width:120px;height:120px;border-radius:50%;" />
            }
        </div>
    </div>

    <!-- Botões -->
    <div class="d-flex gap-2 mt-4">
        <button type="submit" id="btnSalvar" class="btn btn-salvar btn-bg">
            <i class="fa fa-save"></i> Salvar Alterações
        </button>
        <a asp-action="Index" class="btn btn-voltar btn-bg">
            <i class="fa fa-arrow-left"></i> Voltar
        </a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            bloquearMenu();

            const form = document.getElementById("formProduto");
            const descricao = document.getElementById("Descricao");
            const precoCompra = document.getElementById("PrecoCompra");
            const precoVenda = document.getElementById("PrecoVenda");
            const estoqueAtual = document.getElementById("EstoqueAtual");
            const estoqueMinimo = document.getElementById("EstoqueMinimo");
            const imagem = document.getElementById("Imagem");

            // Foco inicial no campo Preço de Compra
            if (precoCompra) {
                precoCompra.focus();
                if (precoCompra.value.trim() !== "") {
                    precoCompra.select();
                }
            }

            if (form && window.FormUtils && typeof FormUtils.enableEnterNavigation === 'function') {
                FormUtils.enableEnterNavigation(form, { allowTextarea: true });
            }

            // Aplicar máscaras de formatação
            if (precoCompra) aplicarMascaraCampo(precoCompra, "valor");
            if (precoVenda) aplicarMascaraCampo(precoVenda, "valor");
            if (estoqueAtual) aplicarMascaraCampo(estoqueAtual, "quantidade");
            if (estoqueMinimo) aplicarMascaraCampo(estoqueMinimo, "quantidade");

            aplicarMaiusculoCampos(".maiusculo");

            // Normalizar valores antes de enviar
            if (form) {
                form.addEventListener("submit", function () {
                    if (precoCompra) semMascaraCampo(precoCompra);
                    if (precoVenda) semMascaraCampo(precoVenda);
                    if (estoqueAtual) semMascaraCampo(estoqueAtual);
                    if (estoqueMinimo) semMascaraCampo(estoqueMinimo);
                    form.submit();
                });
            }
        });
    </script>
}