@model IEnumerable<Ordem_Servicos_Web.Models.Produto>

@{
    ViewData["Title"] = "Gerenciamento de Produtos";
    int page = ViewBag.Page ?? 1;
    int totalPaginas = ViewBag.TotalPaginas ?? 1;
    int totalRegistros = ViewBag.TotalRegistros ?? 0;
    string search = ViewBag.Search ?? "";
}

<h2 class="text-center">@ViewData["Title"]</h2>

<div class="table-responsive">
    <table class="table-os table-os-striped table-os-bordered table-os-condensed w-100 mb-0">        
        <thead class="table-dark">
            <tr>
                <th style="width:150px;">Ações</th>
                <th>IMAGEM</th>
                <th class="sortable">ID</th>
                <th class="sortable">CÓDIGO INTERNO</th>
                <th class="sortable">CÓDIGO FABRICANTE</th>
                <th class="sortable">DESCRIÇÃO DO PRODUTO </th>
                <th class="sortable">NOME DO FORNECEDOR</th>
                <th>DESCRIÇÃO DA MARCA</th>
                <th>DESCRIÇÃO DO MODELO</th>
                <th>DESCRIÇÃO DA UNIDADE</th>
                <th>PREÇO COMPRA</th>
                <th>PREÇO VENDA</th>
                <th>EST, ATUAL</th>
                <th>EST. MINIMO</th>
            </tr>
        </thead>

        <tbody id="produtosTable">
            @foreach (var produto in Model)
            {
                <tr>
                    <td>
                        <a asp-action="Alterar" asp-route-id="@produto.IdProduto" class="btn btn-alterar btn-sm">
                            <i class="fa fa-edit"></i> Alterar
                        </a>
                        <a asp-action="Excluir" asp-route-id="@produto.IdProduto" class="btn btn-excluir btn-sm">
                            <i class="fa fa-trash"></i> Excluir
                        </a>
                        <a asp-action="Detalhes" asp-route-id="@produto.IdProduto" class="btn btn-detalhes btn-sm">
                            <i class="fa fa-eye"></i> Detalhes
                        </a>
                    </td>
                    <td>
                        @if (produto.Imagem != null)
                        {
                            <img src="data:image/png;base64,@Convert.ToBase64String(produto.Imagem)"
                                 alt="Foto do Produto" style="width:50px;height:50px;border-radius:50%;" />
                        }
                        else
                        {
                            <span>Sem foto</span>
                        }
                    </td>
                    <td class="text-end>@produto.IdProduto</td>
                    <td>@produto.IdProdutoInterno</td>
                    <td>@produto.IdProdutoFabricante</td>
                    <td>@produto.Descricao</td>
                    <td>@produto.Fornecedor?.NomeRazaoSocial</td>
                    <td>@produto.Marca?.Descricao</td>
                    <td>@produto.Modelo?.Descricao</td>
                    <td>@produto.Unidade?.Descricao</td>
                    <td class="text-end">@produto.PrecoCompraFormatado</td>
                    <td class="text-end">@produto.PrecoVendaFormatado</td>
                    <td class="text-end">@produto.EstoqueAtualFormatado</td>
                    <td class ="text-end">@produto.EstoqueMinimoFormatado</td>
                </tr>
            }
        </tbody>
    </table>
</div>

<input type="text" id="searchBox" value="@search"
       class="input-pesquisa"
       placeholder="..." style="max-width:1000px;" />

<!-- Rodapé -->
<div class="d-flex justify-content-between align-items-center mt-2 flex-wrap">
    <div class="d-flex align-items-center flex-wrap">
        <a class="btn btn-navegacao btn-bg me-2 @(page == 1 ? "disabled" : "")"
           asp-action="Index" asp-route-page="@(page - 1)" asp-route-search="@search">
            <i class="fa fa-arrow-left"></i> Anterior
        </a>

        <span class="fw-bold text-black me-2">Página: @(page) - @totalPaginas</span>

        <a class="btn btn-navegacao btn-bg me-3 @(page == totalPaginas ? "disabled" : "")"
           asp-action="Index" asp-route-page="@(page + 1)" asp-route-search="@search">
            Próximo <i class="fa fa-arrow-right"></i>
        </a>

        <span id="totalRegistros" class="fw-bold text-black me-2">Total de Registros: @totalRegistros</span>
    </div>

    <div class="d-flex gap-2">
        <a asp-action="Create" class="btn btn-novo btn-bg">
            <i class="fa fa-plus"></i> Novo Produto
        </a>
        <a asp-controller="Home" asp-action="Index" class="btn btn-voltar btn-bg" onclick="liberarMenu()">
            <i class="fa fa-home"></i> Voltar
        </a>
    </div>
</div>

@section Scripts {
    
    <!-- Importa o arquivo JS reutilizável -->
    <script src="~/js/PesquisaDinamica.js"></script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            bloquearMenu();

            initSortableTable({
                tableSelector: "table",
                searchBoxSelector: "#searchBox",
                targetTableBody: "#produtosTable",
                totalRegSelector: "#totalRegistros",
                colMap: {
                    2: "IdProduto",
                    3: "IdProdutoInterno",
                    4: "IdProdutoFabricante",
                    5: "Descricao",
                    6: "FornecedorNome"
                },
                initialCol: 5,
                initialDirection: true,
                searchUrl: '@Url.Action("Search", "Produtos")',
                indexUrl: '@Url.Action("Index", "Produtos", new { page = 1 })',
                defaultSearchColumn: "Descricao",
                placeholders: {
                    "IdProduto": "Pesquisar Produto por ID...",
                    "IdProdutoInterno": "Pesquisar Produto por Código Interno...",
                    "IdProdutoFabricante": "Pesquisar Produto por Código do Fabricante...",
										"Descricao": "Pesquisar Produto por Descrição...",
                                        "FornecedorNome": "Pesquisar Produto por Fornecedor..."
                }
            });
        });
    </script>
}