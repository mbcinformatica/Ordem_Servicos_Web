@model Ordem_Servicos_Web.ViewModels.ProdutoViewModel

@{
    ViewData["Title"] = "Detalhes do Produto";
}

<h2 class="text-center">@ViewData["Title"]</h2>

<partial name="_MensagemToast" />

<div class="card shadow-sm mt-4">
    <div class="card-header bg-dark text-white">
        <h5 class="mb-0">Informações do Produto</h5>
    </div>
    <div class="card-body">
        <div class="row mb-1">
            <div class="col-md-5 text-center">
                @if (Model.Imagem != null)
                {
                    <img src="data:image/png;base64,@Convert.ToBase64String(Model.Imagem)"
                         alt="Imagem do Produto"
                         style="width:250px;height:250px;border-radius:50%;border:2px solid #ccc;" />
                }
                else
                {
                    <div class="bg-light d-flex align-items-center justify-content-center"
                         style="width:250px;height:250px;border-radius:50%;border:2px solid #ccc;">
                        <span class="text-muted">Sem foto</span>
                    </div>
                }
            </div>
            <div class="col-md-7">
                <dl class="row">
                    <dt class="col-detalhe">ID</dt>
                    <dd class="col-sm-7">@Model.IdProduto</dd>

                    <dt class="col-detalhe">Código Interno</dt>
                    <dd class="col-sm-7">@Model.IdProdutoInterno</dd>

                    <dt class="col-detalhe">Código Fabricante</dt>
                    <dd class="col-sm-7">@Model.IdProdutoFabricante</dd>

                    <dt class="col-detalhe">Nome Fornecedor</dt>
                    <dd class="col-sm-7">@Model.NomeFornecedor</dd>

                    <dt class="col-detalhe">Descrição da Marca</dt>
                    <dd class="col-sm-7">@Model.NomeMarca</dd>

                    <dt class="col-detalhe">Descrição do Modelo</dt>
                    <dd class="col-sm-7">@Model.NomeModelo</dd>

                    <dt class="col-detalhe">Descrição da Unidade</dt>
                    <dd class="col-sm-7">@Model.NomeUnidade</dd>

                    <dt class="col-detalhe">Preço de Compra</dt>
                    <dd class="col-sm-7">@Model.PrecoCompraFormatado</dd>


                    <dt class="col-detalhe">Preço de Venda</dt>
                    <dd class="col-sm-7">@Model.PrecoVendaFormatado</dd>

                    <dt class="col-detalhe">Estoque Atual</dt>
                    <dd class="col-sm-7">@Model.EstoqueAtual</dd>

                    <dt class="col-detalhe">Estoque Mínimo</dt>
                    <dd class="col-sm-7">@Model.EstoqueMinimo</dd>
                </dl>
            </div>
        </div>
    </div>
    <div class="card-footer d-flex justify-content-between">
        <a asp-action="Index" class="btn btn-voltar btn-bg">
            <i class="fa fa-arrow-left"></i> Voltar
        </a>
        <div class="d-flex gap-2">
            <a asp-action="Alterar" asp-route-id="@Model.IdProduto" class="btn btn-alterar btn-bg">
                <i class="fa fa-edit"></i> Alterar
            </a>
            <a asp-action="Excluir" asp-route-id="@Model.IdProduto" class="btn btn-excluir btn-bg">
                <i class="fa fa-trash"></i> Excluir
            </a>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            bloquearMenu();
        });
    </script>
}