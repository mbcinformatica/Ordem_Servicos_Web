@model IEnumerable<Ordem_Servicos_Web.Models.Cliente>

@{
    ViewData["Title"] = "Gerenciamento de Clientes";
    int page = ViewBag.Page ?? 1;
    int totalPaginas = ViewBag.TotalPaginas ?? 1;
    int totalRegistros = ViewBag.TotalRegistros ?? 0;
    string search = ViewBag.Search ?? "";
}

<h2 class="text-center">@ViewData["Title"]</h2>

<div class="table-responsive">
    <table class="table-os table-os-striped table-os-bordered table-os-condensed w-100 mb-0">        
        <thead class="table-dark">
            <tr>
                <th style="width:150px;">Ações</th>
                <th class="sortable">ID</th>
                <th>TIPO/PESSOA</th>
                <th class="sortable">CPF/CNPJ</th>
                <th class="sortable">NOME/RAZÃO SOCIAL</th>
                <th>ENDEREÇO</th>
                <th>NÚMERO</th>
                <th>BAIRRO</th>
                <th>MUNICÍPIO</th>
                <th>UF</th>
                <th>CEP</th>
                <th>CONTATO</th>
                <th>FONE FIXO</th>
                <th>FONE CELULAR</th>
                <th>E-MAIL</th>
                <th>DATA CADASTRO</th>
            </tr>
        </thead>

        <tbody id="clientesTable">
            @foreach (var cliente in Model)
            {
                <tr>
                    <td>
                        <a asp-action="Alterar" asp-route-id="@cliente.IdCliente" class="btn btn-alterar btn-sm">
                            <i class="fa fa-edit"></i> Alterar
                        </a>
                        <a asp-action="Excluir" asp-route-id="@cliente.IdCliente" class="btn btn-excluir btn-sm">
                            <i class="fa fa-trash"></i> Excluir
                        </a>
                    </td>
                    <td class="text-end">@cliente.IdCliente</td>
                    <td class="text-center">@cliente.TipoPessoa</td>
                    <td class="text-end">@cliente.CpfCnpjFormatado</td>
                    <td>@cliente.NomeRazaoSocial</td>
                    <td>@cliente.Endereco</td>
                    <td class="text-end">@cliente.Numero</td>
                    <td>@cliente.Bairro</td>
                    <td>@cliente.Municipio</td>
                    <td class="text-center">@cliente.Uf</td>
                    <td class="text-center">@cliente.CepFormatado</td>
                    <td>@cliente.Contato</td>
                    <td class="text-center">@cliente.FoneFixoFormatado</td>
                    <td class="text-center">@cliente.FoneCelularFormatado</td>
                    <td>@cliente.EmailFormatado</td>
                    <td class="text-end">@cliente.DataCadastro.ToShortDateString()</td>
                </tr>
            }
        </tbody>
    </table>
</div>

<input type="text" id="searchBox" value="@search"
       class="input-pesquisa"
       placeholder="..." style="max-width:1000px;" />

<!-- Rodapé -->
<div class="d-flex justify-content-between align-items-center mt-2 flex-wrap">
    <div class="d-flex align-items-center flex-wrap">
        <a class="btn btn-navegacao btn-bg me-2 @(page == 1 ? "disabled" : "")"
           asp-action="Index" asp-route-page="@(page - 1)" asp-route-search="@search">
            <i class="fa fa-arrow-left"></i> Anterior
        </a>

        <span class="fw-bold text-black me-2">Página: @(page) - @totalPaginas</span>

        <a class="btn btn-navegacao btn-bg me-3 @(page == totalPaginas ? "disabled" : "")"
           asp-action="Index" asp-route-page="@(page + 1)" asp-route-search="@search">
            Próximo <i class="fa fa-arrow-right"></i>
        </a>

        <span id="totalRegistros" class="fw-bold text-black me-2">Total de Registros: @totalRegistros</span>
    </div>

    <div class="d-flex gap-2">
        <a asp-action="Create" class="btn btn-novo btn-bg">
            <i class="fa fa-plus"></i> Novo Cliente
        </a>
        <a asp-controller="Home" asp-action="Index" class="btn btn-voltar btn-bg" onclick="liberarMenu()">
            <i class="fa fa-home"></i> Voltar
        </a>
    </div>
</div>

@section Scripts {
    
    <!-- Importa o arquivo JS reutilizável -->
    <script src="~/js/PesquisaDinamica.js"></script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            bloquearMenu();

            initSortableTable({
                tableSelector: "table",
                searchBoxSelector: "#searchBox",
                targetTableBody: "#clientesTable",
                totalRegSelector: "#totalRegistros",
                colMap: {
                    1: "IdCliente",
                    3: "CpfCnpj",
                    4: "NomeRazaoSocial"
                },
                initialCol: 4,              // começa em NomeRazaoSocial
                initialDirection: true,     // ascendente
                searchUrl: '@Url.Action("Search", "Clientes")',
                indexUrl: '@Url.Action("Index", "Clientes", new { page = 1 })',
                defaultSearchColumn: "NomeRazaoSocial",
                placeholders: {
                    "IdCliente": "Pesquisar Cliente por ID...",
                    "CpfCnpj": "Pesquisar Cliente por CPF/CNPJ...",
                    "NomeRazaoSocial": "Pesquisar Cliente por Nome/Razão Social..."
                }
            });
        });
    </script>
}