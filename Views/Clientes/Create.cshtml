@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            bloquearMenu();

            const tipoPessoa   = document.getElementById("TipoPessoa");
            const cpfCnpj      = document.getElementById("CpfCnpj");
            const cep          = document.getElementById("Cep");
            const foneFixo     = document.getElementById("FoneFixo");
            const foneCelular  = document.getElementById("FoneCelular");
            const email        = document.getElementById("Email");
            const form         = document.getElementById("formCliente");
            const btnSalvar    = document.getElementById("btnSalvar");

            const camposObrigatorios = [
                "CpfCnpj",
                "NomeRazaoSocial",
                "Cep",
                "Endereco",
                "Bairro",
                "Municipio",
                "Uf"
            ];

            aplicarMaiusculoCampos(".maiusculo");
            aplicarMinusculoCampos(".minusculo");

            // Aplicar máscaras de formatação
            if (cpfCnpj) aplicarCpfCnpj(cpfCnpj, tipoPessoa.value);
            if (cep) aplicarMascaraCampo(cep, "cep");
            if (foneFixo) aplicarMascaraCampo(foneFixo, "telefone");
            if (foneCelular) aplicarMascaraCampo(foneCelular, "telefone");

            // 🔹 Configuração automática de validação
            if (form) {
                ValidacaoUtils.configurarValidacaoCampos(form, camposObrigatorios, "CLIENTES");
                ValidacaoUtils.validarFormulario(form, camposObrigatorios);

                if (window.FormUtils && typeof FormUtils.enableEnterNavigation === 'function') {
                    FormUtils.enableEnterNavigation(form, { allowTextarea: true });
                }

                form.addEventListener("submit", function () {
                    if (cpfCnpj)     semMascaraCampo(cpfCnpj);
                    if (cep)         semMascaraCampo(cep);
                    if (foneFixo)    semMascaraCampo(foneFixo);
                    if (foneCelular) semMascaraCampo(foneCelular);
                });
            }

            // Atualizar máscara ao trocar tipo de pessoa
            if (tipoPessoa) {
                tipoPessoa.addEventListener("change", function () {
                    cpfCnpj.value = "";
                    aplicarCpfCnpj(cpfCnpj, tipoPessoa.value);
                });
            }

            // Focar no botão salvar a partir do campo de email
            if (email && btnSalvar) {
                email.addEventListener("blur", function () {
                    if (email.classList.contains("Invalid")) {
                        email.focus();
                    } else {
                        btnSalvar.focus();
                    }
                });
                email.addEventListener("keydown", function (e) {
                    if (e.key === "Enter") {
                        e.preventDefault();
                        btnSalvar.focus();
                    }
                });
            }
        });
    </script>
