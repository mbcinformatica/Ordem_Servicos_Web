@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/formatters.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // Foca no campo Tipo de Pessoa ao carregar
            const tipoPessoa = document.getElementById("TipoPessoa");
            const cpfCnpj = document.getElementById("CpfCnpj");
            const campos = document.querySelectorAll("input, select, textarea");
            const email = document.getElementById("Email");
            const cep = document.getElementById("Cep");
            const fone2 = document.getElementById("Fone2");
            const fone1 = document.getElementById("Fone1");
            const btnSalvar = document.querySelector("button[type='submit']");

            // Enter vai para o próximo campo
            campos.forEach(function (el, index) {
                el.addEventListener("keydown", function (e) {
                    if (e.key === "Enter") {
                        e.preventDefault();
                        const next = campos[index + 1];
                        if (next) next.focus();
                    }
                });
            });
            // Campos de texto que devem ficar em maiúsculo
            document.querySelectorAll("#NomeRazaoSocial, #Numero, #Endereco, #Bairro, #Municipio, #Contato, #Uf")
                .forEach(input => input.addEventListener("blur", () => {
                    input.value = input.value.toUpperCase().trim();
                }));
            // Apenas números
            [cpfCnpj, cep, fone1, fone2].forEach(campo => {
                if (campo) {
                    campo.addEventListener("input", () => apenasNumeros(campo));
                }
            });

            if (cpfCnpj) {
                 cpfCnpj.addEventListener("blur", function () {
                     const cpfcnpj = cpfCnpj.value.trim();
                     if (cpfcnpj.length > 0) {
                         fetch(`/Clientes/VerificarCpfCnpj?cpfcnpj=${encodeURIComponent(cpfcnpj)}`)
                             .then(response => response.json())
                             .then(data => {
                                 if (data.existe) {
                                     mostrarToast("CPF/CNPJ já Cadastrado.", "aviso");
                                     cpfCnpj.focus();
                                 } else {
                                     mostrarToast("CPF/CNPJ Disponível.", "sucesso");
                                     cpfCnpj.value = formatCpfCnpj(cpfCnpj.value, tipoPessoa.value);
                                     if (!validarCpfCnpj(cpfCnpj, tipoPessoa.value)) {
                                         cpfCnpj.focus();
                                     } else {
                                         buscarCNPJ("CpfCnpj", "TipoPessoa", "NomeRazaoSocial", "Endereco", "Numero", "Bairro", "Municipio", "Uf", "Cep", "Fone1", "Fone2", "Email", "Contato");
                                     }
                                 }
                             })
                             .catch(() => {
                                 mostrarToast("Erro ao Verificar CPF/CNPJ.", "erro");
                             });
                     }
                 });
            }
            // CEP
            if (cep) {
                cep.addEventListener("blur", () => {
                    cep.value = formatCep(cep.value);
                    if (!validarCep(cep)) {
                        cep.focus();
                    } else {
                        buscarCEP("Cep", "Endereco", "Bairro", "Municipio", "Uf");
                    }
                });
            }
            // Telefone 1
            if (fone1) fone1.addEventListener("blur", () => {
                fone1.value = formatTelefone(fone1.value);
                if (!validarTelefone(fone1)) fone1.focus();
            });

            // Telefone 2
            if (fone2) fone2.addEventListener("blur", () => {
                fone2.value = formatTelefone(fone2.value);
                if (!validarTelefone(fone2)) fone2.focus();
            });

            // Email
            if (email && btnSalvar) {
                email.addEventListener("keydown", function (e) {
                    if (e.key === "Enter") {
                        e.preventDefault();
                        email.value = converteParaMinusculo(email.value);
                        if (!validarEmail(email)) {
                            email.focus();
                        } else {
                            btnSalvar.focus();
                        }
                    }
                });
            }

            // Antes de enviar → remove formatação
            const form = document.getElementById("formCliente");
            if (form) {
                form.addEventListener("submit", function () {
                    if (cpfCnpj) cpfCnpj.value = SemFormatacao(cpfCnpj.value);
                    if (cep) cep.value = SemFormatacao(cep.value);
                    if (fone1) fone1.value = SemFormatacao(fone1.value);
                    if (fone2) fone2.value = SemFormatacao(fone2.value);
                    if (email) email.value = converteParaMinusculo(email.value);
                });
            }
        });
    </script>
}


