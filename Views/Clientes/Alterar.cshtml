            const form = document.getElementById("formCliente");

            if (nomeRazao) nomeRazao.focus();

            // Enter vai para o próximo campo
            campos.forEach(function (el, index) {
                el.addEventListener("keydown", function (e) {
                    if (e.key === "Enter") {
                        e.preventDefault();
                        const next = campos[index + 1];
                        if (next) next.focus();
