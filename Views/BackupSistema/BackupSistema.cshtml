@{
    ViewData["Title"] = "Backup Sistema.";
}

<h2 class="text-center">@ViewData["Title"]</h2>

<partial name="_MensagemToast" />

<modal-confirmacao id-modal="confirmaBackupSistema"
                   icone="fa fa-save"
                   titulo="Confirmação"
                   mensagem="Deseja Realizaro Backup do Sistema Agora?"
                   classe-mensagem="mensagem-sucesso-modal"
                   action-controller="BackupSistema"
                   action-name="BackupSistema"
                   id-registro=""
                   icone-botao-principal="fa fa-save"
                   texto-botao-principal="Executar Backup"
                   classe-botao-principal="btn-salvar"
                   texto-botao-cancelar="Voltar"
                   classe-botao-secundario="btn-voltar"
                   action-controller-secundario="Home"
                   action-name-secundario="Index">
</modal-confirmacao>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            bloquearMenu();

            // Abre o modal automaticamente ao carregar a página
            var modalElement = document.getElementById("confirmaBackupSistema");
            if (modalElement) {
                var modal = new bootstrap.Modal(modalElement);
                modal.show();
            }
        });
    </script>
}