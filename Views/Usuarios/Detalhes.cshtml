@model Ordem_Servicos_Web.Models.Usuario

@{
    ViewData["Title"] = "Detalhes do Usuário";
}

<h2 class="text-center">@ViewData["Title"]</h2>

<partial name="_MensagemToast" />

<div class="card shadow-sm mt-4">
    <div class="card-header bg-dark text-white">
        <h5 class="mb-0">Informações do Usuário</h5>
    </div>
    <div class="card-body">
        <div class="row mb-1">
            <div class="col-md-5 text-center">
                @if (Model.Imagem != null)
                {
                    <img src="data:image/png;base64,@Convert.ToBase64String(Model.Imagem)"
                         alt="Foto do Usuário"
                         style="width:250px;height:250px;border-radius:50%;border:2px solid #ccc;" />
                }
                else
                {
                    <div class="bg-light d-flex align-items-center justify-content-center"
                         style="width:250px;height:250px;border-radius:50%;border:2px solid #ccc;">
                        <span class="text-muted">Sem foto</span>
                    </div>
                }
            </div>
            <div class="col-md-7">
                <dl class="row">
                    <dt class=".col-sm-3">ID</dt>
                    <dd class="col-sm-7">@Model.IdUsuario</dd>

                    <dt class=".col-sm-3">Nome</dt>
                    <dd class="col-sm-7">@Model.NomeUsuario</dd>

                    <dt class=".col-sm-3">Login</dt>
                    <dd class="col-sm-7">@Model.Login</dd>

                    <dt class=".col-sm-3">Email</dt>
                    <dd class="col-sm-7">@Model.EmailFormatado</dd>

                    <dt class=".col-sm-3">Fone Fixo</dt>
                    <dd class="col-sm-7">@Model.FoneFixoFormatado</dd>

                    <dt class=".col-sm-3">Fone Celular</dt>
                    <dd class="col-sm-7">@Model.FoneCelularFormatado</dd>

                    <dt class=".col-sm-3">CEP</dt>
                    <dd class="col-sm-7">@Model.CepFormatado</dd>

                    <dt class=".col-sm-3">Endereço</dt>
                    <dd class="col-sm-7">@Model.Endereco, Nº @Model.Numero</dd>

                    <dt class=".col-sm-3">Bairro</dt>
                    <dd class="col-sm-7">@Model.Bairro</dd>

                    <dt class=".col-sm-3">Município</dt>
                    <dd class="col-sm-7">@Model.Municipio - @Model.Uf</dd>

                    <dt class=".col-sm-3">Data Cadastro</dt>
                    <dd class="col-sm-7">@Model.DataCadastro.ToShortDateString()</dd>
                </dl>
            </div>
        </div>
    </div>
    <div class="card-footer d-flex justify-content-between">
        <a asp-action="Index" class="btn btn-voltar btn-bg">
            <i class="fa fa-arrow-left"></i> Voltar
        </a>
        <div class="d-flex gap-2">
            <a asp-action="Alterar" asp-route-id="@Model.IdUsuario" class="btn btn-alterar  btn-bg">
                <i class="fa fa-edit"></i> Alterar
            </a>
            <a asp-action="Excluir" asp-route-id="@Model.IdUsuario" class="btn btn-excluir  btn-bg">
                <i class="fa fa-trash"></i> Excluir
            </a>
        </div>
    </div>
</div>
@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            bloquearMenu();
        });
    </script>
}