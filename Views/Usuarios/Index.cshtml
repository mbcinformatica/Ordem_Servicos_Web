    <script>
        document.addEventListener("DOMContentLoaded", function () {
            var modalElement = document.getElementById("mensagemModal");
            if (modalElement) {
                var modal = new bootstrap.Modal(modalElement);
                modal.show();
            }

            if (typeof aplicarFormatacaoTabela === "function") {
                aplicarFormatacaoTabela();
            }
        });

        // Busca dinâmica
        document.getElementById("searchBox").addEventListener("keyup", function () {
            var searchValue = this.value.trim();

            if (searchValue.length > 0) {
                fetch('@Url.Action("Search", "Usuarios")?search=' + encodeURIComponent(searchValue))
                    .then(response => response.text())
                    .then(html => {
                        document.getElementById("usuariosTable").innerHTML = html;

                        var total = document.querySelectorAll("#usuariosTable tr").length;
                        document.getElementById("totalRegistros").innerText = "Total de Registros: " + total;

                        if (typeof aplicarFormatacaoTabela === "function") {
                            aplicarFormatacaoTabela();
                        }
                    });
            } else {
                window.location.href = '@Url.Action("Index", "Usuarios", new { page = 1 })';
            }
        });

        // Corrigido seletor para usuariosTable
        function aplicarFormatacaoTabela() {
            document.querySelectorAll("#usuariosTable tr").forEach(tr => {
                let cep = tr.children[5];   // ajustado índice por nova coluna Foto
                let fone1 = tr.children[11];
                let fone2 = tr.children[12];
                let email = tr.children[13];

                if (cep) cep.innerText = formatCep(cep.innerText);
                if (fone1) fone1.innerText = formatTelefone(fone1.innerText);
                if (fone2) fone2.innerText = formatTelefone(fone2.innerText);
                if (email) email.innerText = converteParaMinusculo(email.innerText);
            });
        }
    </script>
}
