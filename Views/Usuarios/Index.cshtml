@model IEnumerable<Ordem_Servicos_Web.Models.Usuario>

@{
    ViewData["Title"] = "Gerenciamento de Usuários";
    int page = ViewBag.Page ?? 1;
    int totalPaginas = ViewBag.TotalPaginas ?? 1;
    int totalRegistros = ViewBag.TotalRegistros ?? 0;
    string search = ViewBag.Search ?? "";
}

<h2 class="text-center">@ViewData["Title"]</h2>

<div class="table-responsive">
    <table class="table-os table-os-striped table-os-bordered table-os-condensed w-100 mb-0">
        <thead class="table-dark">
            <tr>
                <th style="width:150px;">Ações</th>
                <th>Foto</th>
                <th class="sortable">ID</th>
                <th class="sortable">NOME</th>
                <th class="sortable">LOGIN</th>
                <th>CEP</th>
                <th>ENDEREÇO</th>
                <th>NÚMERO</th>
                <th>BAIRRO</th>
                <th>MUNICÍPIO</th>
                <th>UF</th>
                <th>FONE FIXO</th>
                <th>FONE CELULAR</th>
                <th>E-MAIL</th>
                <th>DATA CADASTRO</th>
            </tr>
        </thead>
        <tbody id="usuariosTable">
            @foreach (var usuario in Model)
            {
                <tr>
                    <td>
                        <a asp-action="Alterar" asp-route-id="@usuario.IdUsuario" class="btn btn-alterar btn-sm">
                            <i class="fa fa-edit"></i> Alterar
                        </a>
                        <a asp-action="Excluir" asp-route-id="@usuario.IdUsuario" class="btn btn-excluir btn-sm">
                            <i class="fa fa-trash"></i> Excluir
                        </a>
                        <a asp-action="Detalhes" asp-route-id="@usuario.IdUsuario" class="btn btn-detalhes btn-sm">
                            <i class="fa fa-eye"></i> Detalhes
                        </a>
                    </td>
                    <td>
                        @if (usuario.Imagem != null)
                        {
                            <img src="data:image/png;base64,@Convert.ToBase64String(usuario.Imagem)"
                                 alt="Foto do Usuário" style="width:50px;height:50px;border-radius:50%;" />
                        }
                        else
                        {
                            <span>Sem foto</span>
                        }
                    </td>
                    <td class="text-end">@usuario.IdUsuario</td>
                    <td>@usuario.NomeUsuario</td>
                    <td>@usuario.Login</td>
                    <td class="text-center">@usuario.CepFormatado</td>
                    <td>@usuario.Endereco</td>
                    <td class="text-end">@usuario.Numero</td>
                    <td>@usuario.Bairro</td>
                    <td>@usuario.Municipio</td>
                    <td class="text-center">@usuario.Uf</td>
                    <td class="text-center">@usuario.FoneFixoFormatado</td>
                    <td class="text-center">@usuario.FoneCelularFormatado</td>
                    <td>@usuario.EmailFormatado</td>
                    <td class="text-end">@usuario.DataCadastro.ToShortDateString()</td>
                </tr>
            }
        </tbody>
    </table>
</div>

<input type="text" id="searchBox" value="@search"
       class="input-pesquisa"
       placeholder="..." style="max-width:1000px;" />

<!-- Rodapé -->
<div class="d-flex justify-content-between align-items-center mt-2 flex-wrap">
    <div class="d-flex align-items-center flex-wrap">
        <a class="btn btn-navegacao btn-bg me-2 @(page == 1 ? "disabled" : "")"
           asp-action="Index" asp-route-page="@(page - 1)" asp-route-search="@search">
            <i class="fa fa-arrow-left"></i> Anterior
        </a>

        <span class="fw-bold text-black me-2">Página: @(page) - @totalPaginas</span>

        <a class="btn btn-navegacao btn-bg me-3 @(page == totalPaginas ? "disabled" : "")"
           asp-action="Index" asp-route-page="@(page + 1)" asp-route-search="@search">
            Próximo <i class="fa fa-arrow-right"></i>
        </a>

        <span id="totalRegistros" class="fw-bold text-black me-2">Total de Registros: @totalRegistros</span>
    </div>

    <div class="d-flex gap-2">
        <a asp-action="Create" class="btn btn-novo btn-bg">
            <i class="fa fa-plus"></i> Novo Usuário
        </a>
        <a asp-controller="Home" asp-action="Index" class="btn btn-voltar btn-bg" onclick="liberarMenu()">
            <i class="fa fa-home"></i> Voltar
        </a>
    </div>
</div>

@section Scripts {
    
    <!-- Importa o arquivo JS reutilizável -->
    <script src="~/js/PesquisaDinamica.js"></script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            bloquearMenu();

            initSortableTable({
                tableSelector: "table",
                searchBoxSelector: "#searchBox",
                targetTableBody: "#usuariosTable",
                totalRegSelector: "#totalRegistros",
                colMap: {
                    2: "IdUsuario",
                    3: "NomeUsuario",
                    4: "Login"
                },
                initialCol: 3,              // começa em NomeRazaoSocial
                initialDirection: true,     // ascendente
                searchUrl: '@Url.Action("Search", "Usuarios")',
                indexUrl: '@Url.Action("Index", "Usuarios", new { page = 1 })',
                defaultSearchColumn: "NomeUsuario",
                placeholders: {
                    "IdUsuario": "Pesquisar Usuário por ID...",
                    "Login": "Pesquisar Usuário por Login...",
                    "NomeUsuario": "Pesquisar Usuário por Nome..."
                }
            });
        });
    </script>
}