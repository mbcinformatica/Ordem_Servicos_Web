@model Ordem_Servicos_Web.Models.CategoriaServico

@{
    ViewData["Title"] = "Nova Categoria de Serviços";
}

<h2 class="text-center">@ViewData["Title"]</h2>

<partial name="_MensagemToast" />

<form asp-action="Create" method="post" id="formCategoriaServico" enctype="multipart/form-data">
    
	<!-- Descrição da CategoriaServico -->
    <div class="row mb-2 g-4">
        <div class="col-auto">
            <label asp-for="Descricao" class="label-destaque">Descrição da Categoria de Serviços</label>
            <input asp-for="Descricao" class="form-control text-uppercase maiusculo" id="Descricao" autofocus style="width:615px;" />
        </div>
    </div>

    <!-- Botões -->
    <div class="d-flex gap-2 mt-4">
        <button type="submit" id="btnSalvar" class="btn btn-bg btn-salvar">
            <i class="fa fa-save"></i> Salvar Categoria de Serviços
        </button>
        <a asp-action="Index" class="btn btn-voltar btn-bg">
            <i class="fa fa-arrow-left"></i> Voltar
        </a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            bloquearMenu();

            const descricao = document.getElementById("Descricao");
            const btnSalvar = document.getElementById("btnSalvar");
            const form = document.getElementById("formCategoriaServico");

            if (descricao) descricao.focus();

            if (form && window.FormUtils && typeof FormUtils.enableEnterNavigation === 'function') {
                FormUtils.enableEnterNavigation(form, { allowTextarea: true });
            }

            aplicarMaiusculoCampos(".maiusculo");

            if (descricao) {
                descricao.addEventListener("blur", function () {
                    const descricaoCategoriaServico = descricao.value.trim();
                    if (descricaoCategoriaServico.length > 0) {
                        fetch(`/CategoriaServicos/VerificarDescricaoCategoriaServico?descricaoCategoriaServico=${encodeURIComponent(descricaoCategoriaServico)}`)
                            .then(response => response.json())
                            .then(data => {
                                if (data.existe) {
                                    mostrarToast("Descrição de Categoria de Serviços já Cadastrada.", "erro");
                                    descricao.focus();
                                }
                            })
                            .catch(() => {
                                mostrarToast("Erro ao Verificar Descrição.", "erro");
                                descricao.focus();
                            });
                    }
                });
            }

			// Descricao
            if (descricao && btnSalvar) {

               // Ao pressionar Enter dentro do campo
                descricao.addEventListener("keydown", function (e) {
                    if (e.key === "Enter") {
                        e.preventDefault(); // evita submit automático
                        btnSalvar.focus();
                    }
                });
            }
        });
    </script>
}